---

import BaseLayout from '../layouts/BaseLayout.astro'

import ProfileCard from '../components/ProfileCard.vue'
import QuestsCard from '../components/QuestsCard.vue'
import RestaurantGrid from '../components/RestaurantGrid.vue'
import RequireAuth from '../components/RequireAuth.vue'
import HeaderPage from '../components/UI/HeaderPage.vue'



const filterTabs = ['Todos', 'Tendencia', 'Promocionados']
---

<BaseLayout>
  <RequireAuth client:load />


 
    <main class="flex-1 min-w-0">

     <HeaderPage title="Dashboard" subtitle="Descubre nuevos restaurantes cerca de tí" client:load/>
   

      <!-- Page content -->
      <div class="px-6 md:px-10 py-8 space-y-8 max-w-350 mx-auto">

        <div
        class="flex flex-col gap-4">
      <ProfileCard client:load />
      </div>

        <!-- Restaurant feed section -->
        <section>
          <div class="flex items-end justify-between mb-5">
            <div>
              <h2 class="font-display text-2xl font-bold">Restaurantes para tí </h2>
              <p class="text-sm text-muted-foreground mt-1">Basado en tu ubicación</p>
            </div>
            <div class="hidden md:flex gap-2">
              {filterTabs.map((t, i) => (
                <button
                  class={`px-4 h-9 rounded-full text-sm font-medium transition border ${
                    i === 0
                      ? 'bg-foreground text-background border-foreground'
                      : 'border-border/60 text-muted-foreground hover:text-foreground hover:border-lime/40'
                  }`}
                >
                  {t}
                </button>
              ))}
            </div>
          </div>

          <RestaurantGrid client:load />
        </section>

        <footer class="py-10 text-center text-xs text-muted-foreground">
          © 2026 rateapp 
        </footer>
      </div>
    </main>

</BaseLayout>
