---
// src/pages/index.astro  ← equivalent of src/routes/index.tsx
import BaseLayout from '../layouts/BaseLayout.astro'
import AppSidebar from '../components/AppSidebar.vue'
import ProfileCard from '../components/ProfileCard.vue'
import QuestsCard from '../components/QuestsCard.vue'
import RestaurantCard from '../components/RestaurantCard.vue'
import RequireAuth from '../components/RequireAuth.vue'
import { restaurants } from '../data/restaurants'

const filterTabs = ['All', 'Trending', 'Nearby', 'Promoted']
---

<BaseLayout>
  <RequireAuth client:load />
  <div class="flex min-h-screen bg-background text-foreground">

    <!-- Sidebar: client:load so Vue reactivity works -->
    <AppSidebar client:load />

    <main class="flex-1 min-w-0">

      <!-- Topbar -->
      <header class="sticky top-0 z-20 flex items-center gap-4 px-6 md:px-10 h-20 border-b border-border/60 bg-background/70 backdrop-blur-xl">
        <form action="/search" method="get" class="relative flex-1 max-w-xl">
          <!-- Search icon inline SVG (no JS needed here) -->
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input
            name="q"
            type="search"
            placeholder="Search restaurants, dishes, neighborhoods…"
            class="w-full h-11 pl-11 pr-12 rounded-full bg-surface border border-border/60 text-sm placeholder:text-muted-foreground focus:outline-none focus:border-lime/60 focus:ring-2 focus:ring-lime/20 transition"
          />
          <button type="submit" class="absolute right-1 top-1/2 -translate-y-1/2 h-9 px-4 rounded-full bg-primary text-primary-content text-sm font-semibold hover:bg-primary-focus transition">
            Buscar
          </button>
        </form>

        <button class="hidden md:inline-flex items-center gap-2 h-11 px-4 rounded-full border border-border/60 bg-surface text-sm hover:border-lime/40 transition">
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="21" y1="4" x2="14" y2="4"/><line x1="10" y1="4" x2="3" y2="4"/><line x1="21" y1="12" x2="12" y2="12"/><line x1="8" y1="12" x2="3" y2="12"/><line x1="21" y1="20" x2="16" y2="20"/><line x1="12" y1="20" x2="3" y2="20"/><circle cx="12" cy="4" r="2"/><circle cx="10" cy="12" r="2"/><circle cx="15" cy="20" r="2"/>
          </svg>
          Filters
        </button>

        <button class="relative grid place-items-center h-11 w-11 rounded-full border border-border/60 bg-surface hover:border-lime/40 transition">
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
          </svg>
          <span class="absolute top-2.5 right-2.5 h-2 w-2 rounded-full bg-lime shadow-[0_0_8px_var(--lime)]" />
        </button>
      </header>

      <!-- Page content -->
      <div class="px-6 md:px-10 py-8 space-y-8 max-w-[1400px] mx-auto">

        <div
        class="flex flex-col gap-4">
      <ProfileCard client:load />
        <QuestsCard client:load />
      </div>

        <!-- Restaurant feed section -->
        <section>
          <div class="flex items-end justify-between mb-5">
            <div>
              <h2 class="font-display text-2xl font-bold">For you</h2>
              <p class="text-sm text-muted-foreground mt-1">Hand-picked spots based on your taste</p>
            </div>
            <div class="hidden md:flex gap-2">
              {filterTabs.map((t, i) => (
                <button
                  class={`px-4 h-9 rounded-full text-sm font-medium transition border ${
                    i === 0
                      ? 'bg-foreground text-background border-foreground'
                      : 'border-border/60 text-muted-foreground hover:text-foreground hover:border-lime/40'
                  }`}
                >
                  {t}
                </button>
              ))}
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            {restaurants.map((r) => (
              <RestaurantCard r={r} client:load />
            ))}
          </div>
        </section>

        <footer class="py-10 text-center text-xs text-muted-foreground">
          © 2026 rateapp · Crafted for hungry humans
        </footer>
      </div>
    </main>
  </div>
</BaseLayout>
