---
import LoginForm from '../LoginForm.vue';
---

<!-- Asume que tienes daisyUI instalado y el tema configurado (recomiendo "cyberpunk" o "dracula" + customizaciones) -->
<section class="bg-base-100 text-base-content min-h-screen flex flex-col items-center justify-center overflow-x-hidden relative">

  <!-- Ambient Decorative Elements (Neon orbs) -->
  <div class="fixed top-[-15%] right-[-15%] w-150 h-150 bg-primary/10 rounded-full blur-[140px] -z-10"></div>
  <div class="fixed bottom-[-15%] left-[-15%] `w-112.5 h-112.5 bg-secondary/15 rounded-full blur-[110px] -z-10"></div>
<div class="hidden md:flex md:col-span-6 flex-col gap-10">
    
  <main class="w-full max-w-350 grid grid-cols-1 md:grid-cols-12 gap-12 px-6 md:px-12 items-center min-h-200]">
    
    
    <!-- Left: Branding & Visual (solo desktop) -->
    <div class="hidden md:flex md:col-span-6 flex-col gap-10">
     
      <div class="relative group">
        <!-- Glow hover effect -->
        <div class="absolute -inset-6 bg-primary/20 rounded-3xl blur-2xl opacity-0 group-hover:opacity-100 transition-all duration-700"></div>
        
        <div class="relative rounded-3xl overflow-hidden aspect-4/5 shadow-2xl border border-base-300/30">
          <img 
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuCtDWOYTiDSGV8ML7bCLRNIxgWNPAcQkGEZ5UjEhH2HCR1OWSf1GP9n9SNyqDMWBRIa5TKrhHCjECUYbVME0bryeY87z5vAVDR4q4mmSkqt_RTF3hbNzDLyVkqAmWzqfX-b0--U-yu21Ew7SWbNcVZ_DODqBi3FG5qBgLh9Se5KZHs-kUjmKcUmmeGuJDMuuyww9oIqth3pMI4uFIR4R1CLwoiaR9HEZiZBmwMHOo8wq6JkXOA5Eh4dQJJiO67yy9OkQ2nM7LzmIx-I"
            alt="Cyber Gastronomy Dish"
            class="w-full h-full object-cover grayscale-25 brightness-75 contrast-125 transition-all group-hover:scale-105 duration-700"
          >
          
          <div class="absolute inset-0 bg-linear-to-t from-base-100/90 via-transparent to-transparent"></div>
          
          <div class="absolute bottom-10 left-10 right-10">
            <p class="uppercase tracking-[3px] text-primary font-medium text-sm mb-2">Experiencia Exclusive</p>
            <h2 class="text-4xl font-bold text-white leading-tight">
              Redefiniendo el placer de comer.
            </h2>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Login Form -->
    <div class="md:col-span-6 flex justify-center">
      <LoginForm client:load />
    </div>
  </main>

  <!-- Footer -->
  <footer class="w-full max-w-7xl mx-auto px-8 py-12 text-center text-xs">
    <p class="font-medium tracking-widest text-base-content/40">
      © 2026 GASTROLINK • CYBER-GASTRONOMY COLLECTIVE
    </p>
    <div class="flex gap-6 justify-center mt-4">
      <a href="#" class="hover:text-primary transition-colors">Privacy Policy</a>
      <a href="#" class="hover:text-primary transition-colors">Terms of Service</a>
    </div>
  </footer>
</section>